@model IEnumerable<Product>

@{
    ViewData["Title"] = "Product Page";
}   

<div class="container mt-4">
    <h2 class="mb-4">Products</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">Price: <strong>@product.Price.ToString("C")</strong></p>
                        <p class="card-text">Status: <span class="badge @(product.Status == ProductStatus.Available ? "bg-success" : "bg-secondary")">@product.Status</span></p>
                        <div class="d-flex gap-2 mt-auto">

                            <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id"
                               class="btn btn-outline-primary flex-fill">
                                View
                            </a>
                            <a asp-controller="Order" asp-action="OrderForm" asp-route-id="@product.Id"
                               class="btn btn-primary @(product.Status != ProductStatus.Available ? "disabled" : "")">
                                Buy
                            </a>

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>