@model MarketPlace.Models.ViewModels.PaymentViewModel

<div class="container mt-4">
    <h2 class="mb-3">Order Confirmation</h2>

    <div class="alert alert-success">
        <strong>Payment Status:</strong> @((string?)TempData["PaymentStatus"] ?? "Completed")
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Product.Name</h5>
            <p class="mb-1"><strong>Price:</strong> @Model.Product.Price.ToString("C")</p>
            <p class="text-muted">@Model.Product.Description</p>

            <hr />
            <p class="mb-1"><strong>Order #</strong> @Model.Order.Id</p>
            <p class="mb-1"><strong>Buyer:</strong> @Model.Order.Name</p>
            <p class="mb-1"><strong>Email:</strong> @Model.Order.Email</p>
            <p class="mb-1"><strong>Contact:</strong> @Model.Order.ContactNumber</p>
            <p class="mb-1"><strong>Address:</strong> @Model.Order.Address</p>
            <p class="mb-1"><strong>Purchase Date:</strong> @Model.Order.PurchaseDate</p>

            <div class="mt-3">
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Back to Products</a>
            </div>
        </div>
    </div>
</div>
