@model IEnumerable<Product>

@{
    ViewData["Title"] = "Product Page";
}
<div class="container-fluid mt-4">
    <h2 class="mb-4">Products</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100 shadow">
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                        <img src="@Url.Content("~/images/" + product.ImageUrl)"
                             alt="@product.Name"
                             class="img-fluid h-100"
                             style="object-fit: contain;" />
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-price">Price: <strong>@product.Price.ToString("C")</strong></p>
                        <p class="card-text">
                            Status:
                            <span class="badge @(product.Status == ProductStatus.Available ? "bg-success" : "bg-danger")">
                                @product.Status
                            </span>
                        </p>

                        <div class="d-flex gap-2 mt-auto">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary flex-fill">View</a>
                            <a asp-controller="Product" asp-action="Checkout" asp-route-id="@product.Id" class="btn btn-primary flex-fill @(product.Status == ProductStatus.Sold ? "disabled" : "")">Buy</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
