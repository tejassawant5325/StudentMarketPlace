@model MarketPlace.Models.ViewModels.PurchaseViewModel

<h2 style="text-align: center;">Purchase Form</h2>
<div style="max-width: 500px; margin: 0 auto;">
@using (Html.BeginForm("Buy", "Product", FormMethod.Post))
{
    @Html.HiddenFor(m => m.ProductId)
    <div class="form-group">
        <label for="Name">Name</label>
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control mb-2", placeholder = "Enter your full name", required = "required", id = "Name" })
    </div>
    <div class="form-group">
        <label for="Email">Email</label>
        @Html.TextBoxFor(m => m.Email, new { type = "email", @class = "form-control mb-2", placeholder = "Enter your email address", required = "required", id = "Email" })
    </div>
    <div class="form-group">
        <label for="ContactNumber">Contact Number</label>
        @Html.TextBoxFor(m => m.ContactNumber, new { @class = "form-control mb-2", placeholder = "Enter your contact number", id = "ContactNumber" })
    </div>
    <div class="form-group mb-0" style="display: flex; flex-direction: column; align-items: flex-start; width: 100%;">
        <label for="Address">Address</label>
        @Html.TextAreaFor(m => m.Address, new { @class = "form-control", rows = "3", placeholder = "Enter your address", id = "Address", style = "margin-bottom:0.75rem; width: 100%;" })
            <button type="submit" class="btn btn-success w-100" style="margin-top:0; width: 100%; border-radius:12px;">Confirm Purchase</button>
    </div>
}
