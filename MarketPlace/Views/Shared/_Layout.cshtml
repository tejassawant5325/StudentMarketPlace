@inject SignInManager<ApplicationUser> signInManager;
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarketPlace</title>
    <link rel="stylesheet" href="~/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/common-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MarketPlace.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"/>
</head>
<body>
    <header>

        @if (signInManager.IsSignedIn(User))
        {
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3 p-2">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Market Place</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Product" asp-action="Index">Products</a>
                            </li>

                            <!-- Become a Seller Dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="sellerDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Become a Seller
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="sellerDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Product" asp-action="AddProduct">Sell Product</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Product" asp-action="ManageProduct">Manage Products</a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Product" asp-action="MyOrders">My Orders</a>
                            </li>
                        </ul>

                        @if (signInManager.IsSignedIn(User))
                        {
                            <form class="d-flex" asp-action="Logout" asp-controller="Account" method="post">
                                <button type="submit" class="btn btn-info">Logout: @User.Identity.Name</button>
                            </form>
                        }
                        else
                        {
                            <ul class="navbar-nav ms-auto mb-2 mb-sm-0">
                                <li class="nav-item">
                                    <a asp-controller="Account" asp-action="Register" class="nav-link">Register</a>
                                </li>
                                <li class="nav-item">
                                    <a asp-controller="Account" asp-action="Login" class="nav-link">Login</a>
                                </li>
                            </ul>
                        }
                    </div>
                </div>
            </nav>
        }
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="border-top footer bg-dark text-light text-center">
        <p class="mb-0">© @DateTime.Now.Year - Market Place | Made with ❤️ for Students</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
