                        <a asp-action="Details" asp-controller="Product" asp-route-id="1" class="btn btn-sm btn-primary">View</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow h-100">
                    <img src="~/images/product2.jpg" class="card-img-top" alt="Product 2">
                    <div class="card-body">
                        <h5 class="card-title">Engineering Books Set</h5>
                        <p class="card-text text-muted">₹600</p>
                        <a asp-action="Details" asp-controller="Product" asp-route-id="2" class="btn btn-sm btn-primary">View</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow h-100">
                    <img src="~/images/product3.jpg" class="card-img-top" alt="Product 3">
                    <div class="card-body">
                        <h5 class="card-title">Scientific Calculator</h5>
                        <p class="card-text text-muted">₹300</p>
                        <a asp-action="Details" asp-controller="Product" asp-route-id="3" class="btn btn-sm btn-primary">View</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow h-100">
                    <img src="~/images/product4.jpg" class="card-img-top" alt="Product 4">
                    <div class="card-body">
                        <h5 class="card-title">Hostel Essentials Kit</h5>
                        <p class="card-text text-muted">₹1,200</p>
                        <a asp-action="Details" asp-controller="Product" asp-route-id="4" class="btn btn-sm btn-primary">View</a>
                    </div>
                </div>
            </div> *@
            @foreach (var product in Model.RecentProducts)
            {
                <div class="col-md-3 mb-3">
                    <div class="card shadow h-100">
                        @* <img src="~/images/@product.ImageUrl" class="card-img-top" alt="@product.Name" /> *@
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                            <img src="@Url.Content("~/images/" + product.ImageUrl)"
                                 alt="@product.Name"
                                 class="img-fluid h-100"
                                 style="object-fit: contain;" />
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">₹@product.Price</p>
                            <a asp-action="Details" asp-controller="Product" asp-route-id="@product.Id" class="btn btn-primary">View</a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-4">
            <a asp-action="Index" asp-controller="Product" class="btn btn-outline-primary">See All Products</a>
        </div>
    </div>

    <!-- Contact Us Section -->
    <div class="mb-5">
        <h2 class="fw-bold text-center mb-4">📩 Contact Us</h2>
        <form class="row g-3 shadow p-4 rounded bg-light" asp-action="ContactUs" asp-controller="Home">
            <div class="col-md-6">
                <label for="name" class="form-label">Your Name</label>
                <input type="text" asp-for="@Model.ContactUs.Name" class="form-control" id="name" placeholder="Enter your name">
            </div>
            <div class="col-md-6">
                <label for="email" class="form-label">Your Email</label>
                <input type="email" asp-for="@Model.ContactUs.Email" class="form-control" id="email" placeholder="Enter your email">
            </div>
            <div class="col-12">
                <label for="message" class="form-label">Message</label>
                <textarea class="form-control" asp-for="@Model.ContactUs.Message" id="message" rows="4" placeholder="Type your message..."></textarea>
            </div>
            <div class="col-12 text-center">
                <button type="submit" class="btn btn-primary">Send Message</button>
            </div>
        </form>
    </div>
</div>

