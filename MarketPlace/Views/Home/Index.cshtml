@model HomePageViewModel;

@{
    ViewData["Title"] = "Student Marketplace";
}

<div class="container-fluid mt-5">

    <!-- Carousel Section -->
    <div id="marketplaceCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
        <div class="carousel-inner rounded shadow">
            <div class="carousel-item active">
                <img src="~/images/B1.jpg" class="d-block w-100" alt="Books">
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-2">
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/B2.jpg" class="d-block w-100" alt="Electronics">
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-2">
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/B3.jpg" class="d-block w-100" alt="Stationery">
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-2">
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#marketplaceCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#marketplaceCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <!-- Recently Added Section -->
    <div class="mb-5">
        <h2 class="fw-bold text-center mb-4">🆕 Recently Added</h2>
        <div class="row">
            @foreach (var product in Model.RecentProducts)
            {
                <div class="col-md-3 mb-3">
                    <div class="card shadow h-100">
                        @* <img src="~/images/@product.ImageUrl" class="card-img-top" alt="@product.Name" /> *@

                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                            @if (product.Price < 1)
                            {
                                <img src="@Url.Content("~/images/notesbg.jpg")"
                                     alt="@product.Name"
                                     class="img-fluid h-100"
                                     style="object-fit: contain;" />
                            }
                            else
                            {
                                <img src="@Url.Content("~/images/" + product.ImageUrl)"
                                     alt="@product.Name"
                                     class="img-fluid h-100"
                                     style="object-fit: contain;" />
                            }
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <h5 class="card-text text-price">₹@product.Price</h5>
                            @if (product.Price < 1)
                            {
                                <div class="d-flex gap-2 mt-auto">
                                    <a asp-controller="Product" asp-action="DownloadFile" asp-route-fileName="@product.ImageUrl" class="btn btn-outline-primary flex-fill">Download</a>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex gap-2 mt-auto">
                                    <a asp-action="Details" asp-controller="Product" asp-route-id="@product.Id" class="btn btn-outline-primary flex-fill">View</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-4 mb-4">
            <a asp-action="Index" asp-controller="Product" class="btn btn-outline-primary">See All Products</a>
        </div>
    </div>

    <!-- Contact Us Section -->
    <div class="mb-5">
        <h2 class="fw-bold text-center mb-4">📩 Contact Us</h2>
        <form class="row g-3 shadow p-4" asp-action="ContactUs" asp-controller="Home">
            <div class="col-md-6">
                <label for="name" class="form-label">Your Name</label>
                <input type="text" asp-for="@Model.ContactUs.Name" class="form-control" id="name" placeholder="Enter your name">
            </div>
            <div class="col-md-6">
                <label for="email" class="form-label">Your Email</label>
                <input type="email" asp-for="@Model.ContactUs.Email" class="form-control" id="email" placeholder="Enter your email">
            </div>
            <div class="col-12">
                <label for="message" class="form-label">Message</label>
                <textarea class="form-control" asp-for="@Model.ContactUs.Message" id="message" rows="4" placeholder="Type your message..."></textarea>
            </div>
            <div class="col-12 text-center">
                <button type="submit" class="btn btn-primary">Send Message</button>
            </div>
        </form>
    </div>
</div>

